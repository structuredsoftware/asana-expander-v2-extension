{
  "name": "Asana Expander v2",
  "homepage_url": "https://github.com/structuredsoftware/asana-expander-extension",
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "asana-expander-v2@structuredsoftware.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "{{firefox}}.permissions": ["tabs", "storage", "*://*.asana.com/*"],
  "{{chrome}}.permissions": ["tabs", "storage"],
  "{{chrome}}.host_permissions": ["*://*.asana.com/*"],
  "{{chrome}}.action": {
    "default_title": "Asana Expander v2",
    "default_popup": "src/popup/popup.html"
  },
  "{{firefox}}.browser_action": {
    "default_title": "Asana Expander v2",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "{{chrome}}.service_worker": "src/background.ts",
    "{{firefox}}.scripts": ["src/background.ts"]
  },
  "content_scripts": [
    {
      "matches": ["https://*.asana.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_end"
    }
  ]
}
